{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "rootDir": "../",
    "outDir": "build",
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  }
}
